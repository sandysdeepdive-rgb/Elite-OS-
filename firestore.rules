rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }
    
    function isAdmin(schoolId) {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.schoolId == schoolId;
    }
    
    function isTeacher(schoolId) {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher' &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.schoolId == schoolId;
    }
    
    function isParent(schoolId) {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'parent' &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.schoolId == schoolId;
    }

    // Users collection
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
    }

    // Schools collection
    match /schools/{schoolId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAdmin(schoolId);
      
      // Subcollections
      match /students/{studentId} {
        allow read: if isAuthenticated() && (isAdmin(schoolId) || isTeacher(schoolId) || isParent(schoolId));
        allow write: if isAdmin(schoolId);
      }
      
      match /teachers/{teacherId} {
        allow read: if isAuthenticated() && (isAdmin(schoolId) || isTeacher(schoolId) || isParent(schoolId));
        allow write: if isAdmin(schoolId);
      }
      
      match /classes/{classId} {
        allow read: if isAuthenticated() && (isAdmin(schoolId) || isTeacher(schoolId) || isParent(schoolId));
        allow write: if isAdmin(schoolId);
      }
      
      match /pendingUsers/{userId} {
        allow read: if isAdmin(schoolId) || isOwner(userId);
        allow create: if isOwner(userId);
        allow delete: if isAdmin(schoolId);
      }
      
      match /chats/{chatId} {
        allow read: if isAuthenticated() && request.auth.uid in resource.data.participants;
        allow create: if isAuthenticated() && request.auth.uid in request.resource.data.participants;
        allow update: if isAuthenticated() && request.auth.uid in resource.data.participants;
        
        match /messages/{messageId} {
          allow read: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/schools/$(schoolId)/chats/$(chatId)).data.participants;
          allow create: if isAuthenticated() && request.auth.uid == request.resource.data.senderId && request.auth.uid in get(/databases/$(database)/documents/schools/$(schoolId)/chats/$(chatId)).data.participants;
        }
      }
      
      match /settings/{settingId} {
        allow read: if isAuthenticated() && (isAdmin(schoolId) || isTeacher(schoolId) || isParent(schoolId));
        allow write: if isAdmin(schoolId);
      }
      
      match /attendance/{attendanceId} {
        allow read: if isAuthenticated() && (isAdmin(schoolId) || isTeacher(schoolId) || isParent(schoolId));
        allow write: if isAdmin(schoolId) || isTeacher(schoolId);
      }
      
      match /reports/{reportId} {
        allow read: if isAuthenticated() && (isAdmin(schoolId) || isTeacher(schoolId) || isParent(schoolId));
        allow write: if isAdmin(schoolId) || isTeacher(schoolId);
      }
    }
  }
}
