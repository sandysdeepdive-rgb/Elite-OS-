rules_version = '2';

// FIRESTORE INDEX REQUIRED: fees — composite index (term ASC, academicYear ASC)
// FIRESTORE INDEX REQUIRED: fees — composite index (studentId ASC, term ASC)
// Create at: https://console.firebase.google.com/project/elite-is/firestore/indexes

service cloud.firestore {
  match /databases/{database}/documents {

    match /public_test/{doc} {
      allow read: if true;
    }

    // DEFAULT DENY
    match /{document=**} {
      allow read, write: if false;
    }

    // ── HELPERS ──────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function isServiceAccount() {
      return request.auth != null
        && request.auth.uid == "KSfYrIyAT7e9d1ut4si7RWFTlJf1";
    }

    function currentUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isApproved(user) {
      return user.status == 'approved';
    }

    function isAdmin(schoolId) {
      let u = currentUserData();
      return isAuthenticated() && u.role == 'admin' && u.schoolId == schoolId && isApproved(u);
    }

    function isTeacher(schoolId) {
      let u = currentUserData();
      return isAuthenticated() && u.role == 'teacher' && u.schoolId == schoolId && isApproved(u);
    }

    function isParent(schoolId) {
      let u = currentUserData();
      return isAuthenticated() && u.role == 'parent' && u.schoolId == schoolId && isApproved(u);
    }

    function belongsToSchool(schoolId) {
      let u = currentUserData();
      return isAuthenticated() && u.schoolId == schoolId && isApproved(u);
    }

    function isValidUser(data) {
      return data.keys().hasAll(['role', 'schoolId', 'email', 'status', 'name'])
        && data.role in ['admin', 'teacher', 'parent']
        && data.schoolId is string
        && data.email is string
        && data.status in ['approved', 'pending', 'rejected'];
    }

    function isValidStudent(data) {
      return data.keys().hasAll(['name', 'class', 'createdAt'])
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.class is string && data.class.size() > 0 && data.class.size() <= 20;
    }

    function isValidFee(data) {
      return data.keys().hasAll(['studentId','studentName','termFee','amountPaid','balance','status','term','academicYear','createdAt'])
        && data.studentId is string
        && data.termFee is number && data.termFee >= 0
        && data.amountPaid is number && data.amountPaid >= 0
        && data.balance is number
        && data.status in ['paid', 'partial', 'unpaid'];
    }

    // ── USERS ────────────────────────────────────────
    match /users/{userId} {
      allow get: if isServiceAccount() || (isAuthenticated() && request.auth.uid == userId);
      allow list: if isServiceAccount();

      allow create: if isServiceAccount()
        || (isAuthenticated()
          && request.auth.uid == userId
          && isValidUser(incoming())
          && incoming().role != 'admin'
          && incoming().status == 'pending');

      allow update: if isServiceAccount()
        || (isAuthenticated()
          && request.auth.uid == userId
          && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'phone', 'updatedAt'])
          && incoming().role == existing().role
          && incoming().status == existing().status
          && incoming().schoolId == existing().schoolId)
        || (isAuthenticated()
          && currentUserData().role == 'admin'
          && currentUserData().schoolId == existing().schoolId
          && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'role', 'linkedId', 'updatedAt'])
          && incoming().status in ['approved', 'pending', 'rejected']
          && incoming().role in ['admin', 'teacher', 'parent']);

      allow delete: if false;
    }

    // ── SCHOOLS ──────────────────────────────────────
    match /schools/{schoolId} {
      allow read: if true;
      allow create: if isServiceAccount();
      allow update: if isAdmin(schoolId) || isServiceAccount();
      allow delete: if false;

      // SETTINGS
      match /settings/{settingId} {
        allow read: if belongsToSchool(schoolId) || isServiceAccount();
        allow write: if isAdmin(schoolId) || isServiceAccount();
      }

      // STUDENTS
      match /students/{studentId} {
        allow get: if isAdmin(schoolId) || isTeacher(schoolId)
          || (isParent(schoolId) && existing().parentUid == request.auth.uid);
        allow list: if isAdmin(schoolId) || isTeacher(schoolId);
        allow create: if isAdmin(schoolId) && isValidStudent(incoming());
        allow update: if isAdmin(schoolId)
          && incoming().diff(existing()).affectedKeys()
            .hasOnly(['name','class','parentContact','parentName','dateOfBirth','gender','updatedAt']);
        allow delete: if isAdmin(schoolId);
      }

      // TEACHERS
      match /teachers/{teacherId} {
        allow read: if belongsToSchool(schoolId);
        allow write: if isAdmin(schoolId) || isServiceAccount();
      }

      // CLASSES
      match /classes/{classId} {
        allow read: if belongsToSchool(schoolId);
        allow write: if isAdmin(schoolId);
      }

      // FEES
      match /fees/{feeId} {
        allow get: if isAdmin(schoolId) || isTeacher(schoolId)
          || (isParent(schoolId) && existing().studentId == currentUserData().linkedId);
        allow list: if isAdmin(schoolId) || isTeacher(schoolId) || isParent(schoolId);
        allow create: if isAdmin(schoolId) || isServiceAccount();
        allow update: if isAdmin(schoolId) || isServiceAccount();
        allow delete: if isAdmin(schoolId);
      }

      // REPORTS
      match /reports/{reportId} {
        allow get: if isAdmin(schoolId) || isTeacher(schoolId)
          || (isParent(schoolId) && existing().studentId == currentUserData().linkedId);
        allow list: if isAdmin(schoolId) || isTeacher(schoolId);
        allow create, update: if isAdmin(schoolId) || isTeacher(schoolId);
        allow delete: if isAdmin(schoolId);
      }

      // ATTENDANCE
      match /attendance/{attendanceId} {
        allow get: if isAdmin(schoolId) || isTeacher(schoolId)
          || (isParent(schoolId) && existing().studentId == currentUserData().linkedId);
        allow list: if isAdmin(schoolId) || isTeacher(schoolId);
        allow create, update: if isAdmin(schoolId)
          || (isTeacher(schoolId) && incoming().teacherId == request.auth.uid);
        allow delete: if isAdmin(schoolId);
      }

      // TIMETABLE
      match /timetable/{timetableId} {
        allow read: if belongsToSchool(schoolId);
        allow write: if isAdmin(schoolId) || isTeacher(schoolId);
      }

      // CHATS
      match /chats/{chatId} {
        allow get: if belongsToSchool(schoolId) && request.auth.uid in existing().participants;
        allow list: if false;
        allow create: if belongsToSchool(schoolId)
          && request.auth.uid in incoming().participants
          && incoming().participants.size() >= 2;
        allow update: if belongsToSchool(schoolId)
          && request.auth.uid in existing().participants
          && incoming().diff(existing()).affectedKeys()
            .hasOnly(['lastMessage', 'time', 'unread', 'updatedAt']);
        allow delete: if false;

        match /messages/{messageId} {
          allow read: if belongsToSchool(schoolId)
            && request.auth.uid in get(/databases/$(database)/documents/schools/$(schoolId)/chats/$(chatId)).data.participants;
          allow create: if belongsToSchool(schoolId)
            && request.auth.uid == incoming().senderId
            && request.auth.uid in get(/databases/$(database)/documents/schools/$(schoolId)/chats/$(chatId)).data.participants;
          allow update, delete: if false;
        }
      }

      // PENDING USERS
      match /pendingUsers/{userId} {
        allow create: if isAuthenticated() && request.auth.uid == userId;
        allow read, delete: if isAdmin(schoolId);
        allow update: if false;
      }

      // PAYMENT SESSIONS
      match /paymentSessions/{sessionId} {
        allow read: if isAdmin(schoolId);
        allow write: if isServiceAccount();
      }

      // TRANSACTIONS
      match /transactions/{txnId} {
        allow get: if isAdmin(schoolId) || isTeacher(schoolId)
          || (isParent(schoolId) && existing().studentId == currentUserData().linkedId);
        allow list: if isAdmin(schoolId) || isTeacher(schoolId);
        allow create: if isAdmin(schoolId) || isServiceAccount();
        allow update, delete: if false;
      }

      // ANNOUNCEMENTS
      match /announcements/{id} {
        allow read: if belongsToSchool(schoolId);
        allow create, update: if isAdmin(schoolId) || isTeacher(schoolId);
        allow delete: if isAdmin(schoolId);
      }

      // NOTIFICATIONS
      match /notifications/{id} {
        allow read: if belongsToSchool(schoolId)
          && existing().recipientUid == request.auth.uid;
        allow create: if isAdmin(schoolId);
        allow update: if belongsToSchool(schoolId)
          && existing().recipientUid == request.auth.uid
          && incoming().diff(existing()).affectedKeys().hasOnly(['read', 'readAt']);
        allow delete: if false;
      }
    }

    // ── CONFIG (Pesapal IPN storage) ─────────────────
    match /config/{docId} {
      allow read, write: if true;
    }
  }
}
